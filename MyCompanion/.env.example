# Miku AI Companion - Environment Configuration
# Copy this file to .env and fill in your actual keys

# === CLOUD AI APIs (Free Tiers) ===
# Groq API (Fast, Free Llama 3 inference) - Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI API (For Vision/GPT-4o-mini fallback) - Optional if using Groq only
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API (Claude for deep reasoning) - Optional
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# === TTS CONFIGURATION ===
# Default Voice (Options: miku_jp, miku_en, saitama_jp, asuka_jp, rei_jp, etc.)
TTS_VOICE=miku_jp
TTS_RATE=1.0
TTS_VOLUME=1.0

# === VISION CONFIGURATION ===
# Screen capture interval (seconds) - Lower = more responsive but higher API usage
VISION_INTERVAL=5.0
# Enable/disable screen monitoring
VISION_ENABLED=true

# === MEMORY CONFIGURATION ===
# Memory directory path
MEMORY_DB_PATH=./memory_db
# Enable dream system (processes memories when idle)
DREAM_SYSTEM_ENABLED=true

# === DESKTOP WIDGET ===
# Widget transparency (0.0 - 1.0)
WIDGET_OPACITY=0.95
# Always on top
ALWAYS_ON_TOP=true

# === MODEL CONFIGURATION ===
# Path to VRM model file
VRM_MODEL_PATH=./assets/models/default.vrm
# Enable physics simulation
PHYSICS_ENABLED=true

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=./logs/miku.log

# === ADVANCED ===
# Enable automation features (mouse/keyboard control)
AUTOMATION_ENABLED=true
# Enable singing feature
SINGING_ENABLED=true
