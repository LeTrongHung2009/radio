# MyCompanion Framework - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# CLOUD API KEYS (Required for LLM, STT, Vision)
# =============================================================================

# Groq API Key (Recommended for fast, free-tier LLM inference)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (Optional - for GPT-4o Vision or Whisper STT)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional - for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HuggingFace Token (Optional - for gated models)
HF_TOKEN=your_huggingface_token_here

# =============================================================================
# TTS CONFIGURATION
# =============================================================================

# Edge TTS Voice Selection (Anime-style female voices)
# Options: ja-JP-NanamiNeural, ja-JP-AoiNeural, en-US-AnaNeural, etc.
TTS_VOICE=ja-JP-NanamiNeural
TTS_RATE=+20%
TTS_VOLUME=+10%

# =============================================================================
# TWITCH INTEGRATION (Optional - for chat interaction)
# =============================================================================

# Twitch Developer App Credentials
TWITCH_APP_ID=your_twitch_app_id
TWITCH_APP_SECRET=your_twitch_app_secret
TWITCH_REDIRECT_URI=http://localhost:17563
TWITCH_CHANNEL=your_channel_name

# =============================================================================
# VTube Studio Configuration (Optional)
# =============================================================================

VTS_HOST=127.0.0.1
VTS_PORT=8001
VTS_AUTH_TOKEN=your_vts_auth_token

# =============================================================================
# SYSTEM SETTINGS
# =============================================================================

# Audio Device Numbers (Run utils/listAudioDevices.py to find these)
MIC_DEVICE_NUMBER=1
SPEAKER_DEVICE_NUMBER=2

# Dashboard Server Port
DASHBOARD_PORT=8080

# Screenshot interval for vision (seconds) - Set high to save resources
SCREENSHOT_INTERVAL=30

# Memory database path
MEMORY_DB_PATH=./memory_db/local_facts.json
IDENTITY_PATH=./memory_db/identity.json

# Personality file path
PERSONALITY_PATH=./persona/private/personality.txt

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
